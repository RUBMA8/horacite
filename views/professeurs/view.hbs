<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>{{professeur.prenom}} {{professeur.nom}}
                </h5>
                <div>
                    {{#if professeur.actif}}
                    <span class="badge bg-success">Actif</span>
                    {{else}}
                    <span class="badge bg-secondary">Inactif</span>
                    {{/if}}
                </div>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <th width="30%">Matricule</th>
                            <td>{{professeur.matricule}}</td>
                        </tr>
                        <tr>
                            <th>Nom complet</th>
                            <td>{{professeur.prenom}} {{professeur.nom}}</td>
                        </tr>
                        <tr>
                            <th>Courriel</th>
                            <td>
                                <a href="mailto:{{professeur.email}}">{{professeur.email}}</a>
                            </td>
                        </tr>
                        {{#if professeur.telephone}}
                        <tr>
                            <th>Téléphone</th>
                            <td>
                                <a href="tel:{{professeur.telephone}}">{{professeur.telephone}}</a>
                            </td>
                        </tr>
                        {{/if}}
                        <tr>
                            <th>Spécialité principale</th>
                            <td>
                                <span class="badge bg-primary">{{professeur.specialite}}</span>
                            </td>
                        </tr>
                        {{#if professeur.specialites_secondaires}}
                        <tr>
                            <th>Spécialités secondaires</th>
                            <td>{{professeur.specialites_secondaires}}</td>
                        </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <a href="/professeurs" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Retour
                    </a>
                    <div>
                        <a href="/professeurs/{{professeur.id}}/edit" class="btn btn-primary">
                            <i class="bi bi-pencil me-2"></i>Modifier
                        </a>
                        <a href="/professeurs/{{professeur.id}}/disponibilites" class="btn btn-info">
                            <i class="bi bi-calendar-check me-2"></i>Disponibilités
                        </a>
                        <a href="/horaires/create?professeur_id={{professeur.id}}" class="btn btn-success">
                            <i class="bi bi-calendar-plus me-2"></i>Planifier
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-clock-history me-2"></i>Disponibilités hebdomadaires
                </h6>
            </div>
            <div class="card-body" >
                {{#if disponibilites}}
                <div class="schedule-grid">
                    {{#each jours}}
                    <div class="schedule-day">
                        <div class="schedule-day-header">{{this.nom}}</div>
                        {{#each this.plages}}
                        <div class="schedule-item" style="border-left-color: #198754;">
                            <div class="time">{{this.heure_debut}} - {{this.heure_fin}}</div>
                        </div>
                        {{else}}
                        <p class="text-muted small">Non disponible</p>
                        {{/each}}
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <p class="text-muted">Aucune disponibilité définie</p>
                <a href="/professeurs/{{professeur.id}}/disponibilites" class="btn btn-outline-primary">
                    <i class="bi bi-plus-lg me-2"></i>Définir les disponibilités
                </a>
                {{/if}}
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-calendar3 me-2"></i>Horaires de la semaine
                </h6>
            </div>
            <div class="card-body">
                {{#if horaires}}
                <ul class="list-group list-group-flush">
                    {{#each horaires}}
                    <li class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <strong>{{jourSemaine this.jour_semaine}}</strong>
                            <span class="text-muted">{{formatTime this.heure_debut}} - {{formatTime this.heure_fin}}</span>
                        </div>
                        <small>
                            <span class="badge bg-info me-1">{{this.cours_code}}</span>
                            {{this.cours_nom}}
                        </small>
                        <br>
                        <small class="text-muted">
                            <i class="bi bi-geo-alt me-1"></i>Salle {{this.salle_code}}
                        </small>
                    </li>
                    {{/each}}
                </ul>
                {{else}}
                <p class="text-muted mb-0">Aucun cours planifié cette semaine</p>
                {{/if}}
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-2"></i>Statistiques
                </h6>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6">
                        <h4 class="mb-0">{{stats.heures_semaine}}</h4>
                        <small class="text-muted">Heures/semaine</small>
                    </div>
                    <div class="col-6">
                        <h4 class="mb-0">{{stats.nb_cours}}</h4>
                        <small class="text-muted">Cours assignés</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
