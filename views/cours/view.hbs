<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="bi bi-book me-2"></i>{{cours.code}} - {{cours.nom}}
                </h5>
                <div>
                    {{#if (eq cours.statut 'actif')}}
                    <span class="badge bg-success">Actif</span>
                    {{else}}
                    <span class="badge bg-warning">Archivé</span>
                    {{/if}}
                </div>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <th width="30%">Code</th>
                            <td>{{cours.code}}</td>
                        </tr>
                        <tr>
                            <th>Nom</th>
                            <td>{{cours.nom}}</td>
                        </tr>
                        <tr>
                            <th>Programme</th>
                            <td>
                                <span class="badge bg-primary">{{cours.programme_code}}</span>
                                {{cours.programme_nom}}
                            </td>
                        </tr>
                        <tr>
                            <th>Étape d'étude</th>
                            <td>{{cours.etape_etude}}</td>
                        </tr>
                        <tr>
                            <th>Durée hebdomadaire</th>
                            <td>{{cours.duree_hebdo}} heures</td>
                        </tr>
                        <tr>
                            <th>Type de salle requis</th>
                            <td>{{typeSalle cours.type_salle_requis}}</td>
                        </tr>
                        <tr>
                            <th>Spécialité requise</th>
                            <td>
                                {{#if cours.specialite_requise}}
                                <span class="badge bg-secondary">{{cours.specialite_requise}}</span>
                                {{else}}
                                <span class="text-muted">Aucune restriction</span>
                                {{/if}}
                            </td>
                        </tr>
                        {{#if cours.credits}}
                        <tr>
                            <th>Crédits</th>
                            <td>{{cours.credits}}</td>
                        </tr>
                        {{/if}}
                        {{#if cours.description}}
                        <tr>
                            <th>Description</th>
                            <td>{{cours.description}}</td>
                        </tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <a href="/cours" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Retour
                    </a>
                    <div>
                        <a href="/cours/{{cours.id}}/edit" class="btn btn-primary">
                            <i class="bi bi-pencil me-2"></i>Modifier
                        </a>
                        <a href="/horaires/create?cours_id={{cours.id}}" class="btn btn-success">
                            <i class="bi bi-calendar-plus me-2"></i>Planifier
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">Sessions associées</h6>
            </div>
            <div class="card-body">
                {{#if sessions}}
                <ul class="list-group list-group-flush">
                    {{#each sessions}}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        {{this.nom}}
                        <span class="badge bg-{{#eq this.statut 'active'}}success{{else}}secondary{{/eq}}">
                            {{statutSession this.statut}}
                        </span>
                    </li>
                    {{/each}}
                </ul>
                {{else}}
                <p class="text-muted mb-0">Aucune session associée</p>
                {{/if}}
            </div>
        </div>
    </div>
</div>
