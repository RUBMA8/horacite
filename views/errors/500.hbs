<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 6rem;"></i>
    <h1 class="display-4 mt-4">Erreur serveur</h1>
    <p class="lead">Une erreur s'est produite</p>
    <p class="text-muted">
        {{message}}
    </p>
    {{#if error.stack}}
    <details class="text-start mt-4">
        <summary class="btn btn-outline-secondary btn-sm">Détails techniques</summary>
        <pre class="bg-light p-3 mt-2 rounded"><code>{{error.stack}}</code></pre>
    </details>
    {{/if}}
    <a href="/dashboard" class="btn btn-primary mt-3">
        <i class="bi bi-house me-2"></i>Retour à l'accueil
    </a>
</div>
