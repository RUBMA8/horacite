<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-plus-lg me-2"></i>Nouvel utilisateur
                </h5>
            </div>
            <div class="card-body">
                <form action="/admin/users/create" method="POST" class="needs-validation" novalidate>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="matricule" class="form-label">Matricule *</label>
                            <input type="text" class="form-control" id="matricule" name="matricule"
                                   required maxlength="50" placeholder="Chargement...">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label">Courriel *</label>
                            <input type="email" class="form-control" id="email" name="email"
                                   required maxlength="100" placeholder="utilisateur@lacite.ca">
                        </div>
                    </div>
 
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="prenom" class="form-label">Prénom *</label>
                            <input type="text" class="form-control" id="prenom" name="prenom"
                                   required minlength="2" maxlength="100"
                                   oninput="autoEmail()">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="nom" class="form-label">Nom *</label>
                            <input type="text" class="form-control" id="nom" name="nom"
                                   required minlength="2" maxlength="100"
                                   oninput="autoEmail()">
                        </div>
                    </div>
 
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="role" class="form-label">Rôle *</label>
                            <select class="form-select" id="role" name="role" required>
                                <option value="responsable">Responsable</option>
                                <option value="admin">Administrateur</option>
                            </select>
                            <div class="form-text">
                                <strong>Responsable:</strong> Gestion des horaires et cours<br>
                                <strong>Administrateur:</strong> Accès complet au système
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="password" class="form-label">Mot de passe temporaire *</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="password" name="password"
                                       required minlength="8" value="{{generatedPassword}}">
                                <button type="button" class="btn btn-outline-secondary" onclick="generatePassword()">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </div>
                            <div class="form-text">
                                L'utilisateur devra changer ce mot de passe à la première connexion
                            </div>
                        </div>
                    </div>
 
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        Un courriel sera envoyé à l'utilisateur avec ses identifiants de connexion.
                    </div>
 
                    <hr>
 
                    <div class="d-flex justify-content-between">
                        <a href="/admin/users" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Annuler
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-2"></i>Créer l'utilisateur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
 
<script>
function generatePassword() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@#$%';
    let password = '';
    for (let i = 0; i < 12; i++) {
        password += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById('password').value = password;
}

// Pré-remplir le matricule selon le rôle sélectionné
async function updateMatricule() {
    const role = document.getElementById('role').value;
    const matInput = document.getElementById('matricule');
    try {
        const res = await fetch(`/admin/users/api/next-matricule?role=${role}`);
        const data = await res.json();
        if (!matInput.dataset.manual) {
            matInput.value = data.matricule;
            matInput.placeholder = data.matricule;
        }
    } catch (e) { /* silencieux */ }
}

// Email auto : prenom.nom@lacite.ca
function autoEmail() {
    const prenom = document.getElementById('prenom').value.trim();
    const nom = document.getElementById('nom').value.trim();
    const emailInput = document.getElementById('email');
    if (emailInput.dataset.manual === 'true') return;
    if (prenom || nom) {
        const normalize = s => s.toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9]/g, '');
        emailInput.value = `${normalize(prenom)}.${normalize(nom)}@lacite.ca`;
    }
}

document.addEventListener('DOMContentLoaded', function() {
    // Charger le matricule initial
    updateMatricule();

    // Détecter modification manuelle du matricule
    document.getElementById('matricule').addEventListener('input', function() {
        this.dataset.manual = 'true';
    });

    // Détecter modification manuelle de l'email
    document.getElementById('email').addEventListener('input', function() {
        this.dataset.manual = 'true';
    });

    // Recalculer le matricule quand le rôle change
    document.getElementById('role').addEventListener('change', function() {
        delete document.getElementById('matricule').dataset.manual;
        updateMatricule();
    });
});
</script>
 
