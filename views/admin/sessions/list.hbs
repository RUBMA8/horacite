<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-range me-2"></i>Gestion des Sessions</h2>
    <a href="/admin/sessions/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Nouvelle session
    </a>
</div>

<div class="card">
    <div class="card-body">
        {{#if sessions}}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Type</th>
                        <th>Annee</th>
                        <th>Dates</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each sessions}}
                    <tr>
                        <td class="fw-bold">{{this.nom}}</td>
                        <td>
                            <span class="badge bg-{{#eq this.type 'automne'}}warning{{else}}{{#eq this.type 'hiver'}}info{{else}}success{{/eq}}{{/eq}}">
                                {{this.type}}
                            </span>
                        </td>
                        <td>{{this.annee}}</td>
                        <td>
                            {{formatDate this.date_debut}} - {{formatDate this.date_fin}}
                        </td>
                        <td>
                            {{#eq this.statut 'active'}}
                            <span class="badge bg-success">Active</span>
                            {{else}}
                            {{#eq this.statut 'planification'}}
                            <span class="badge bg-warning">Planification</span>
                            {{else}}
                            <span class="badge bg-secondary">Terminee</span>
                            {{/eq}}
                            {{/eq}}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="/admin/sessions/{{this.id}}/edit" class="btn btn-outline-secondary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {{#eq this.statut 'planification'}}
                                <form action="/admin/sessions/{{this.id}}/set-active" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-success" title="Activer"
                                            onclick="return confirm('Activer cette session ? Les autres sessions actives seront desactivees.');">
                                        <i class="bi bi-play-fill"></i>
                                    </button>
                                </form>
                                {{/eq}}
                                {{#eq this.statut 'active'}}
                                <form action="/admin/sessions/{{this.id}}/terminate" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary" title="Terminer"
                                            onclick="return confirm('Terminer cette session ?');">
                                        <i class="bi bi-stop-fill"></i>
                                    </button>
                                </form>
                                {{/eq}}
                                {{#neq this.statut 'active'}}
                                <form action="/admin/sessions/{{this.id}}/delete" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger" title="Supprimer"
                                            onclick="return confirm('Supprimer cette session ? Cette action est irreversible.');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                                {{/neq}}
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        {{> pagination}}
        {{else}}
        <div class="empty-state">
            <i class="bi bi-calendar-range"></i>
            <h5 class="mt-3">Aucune session trouvee</h5>
            <a href="/admin/sessions/create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Creer une session
            </a>
        </div>
        {{/if}}
    </div>
</div>
