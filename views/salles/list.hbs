<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-door-open me-2"></i>Gestion des Salles</h2>
    <a href="/salles/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Nouvelle salle
    </a>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Filtres
    </div>
    <div class="card-body">
        <form action="/salles" method="GET" class="row g-3">
            <div class="col-md-4">
                <label for="type" class="form-label">Type</label>
                <select class="form-select" id="type" name="type" onchange="this.form.submit()">
                    <option value="">Tous les types</option>
                    {{#each types}}
                    <option value="{{this.value}}" {{selected this.value ../filters.type}}>
                        {{this.label}}
                    </option>
                    {{/each}}
                </select>
            </div>
            <div class="col-md-4">
                <label for="capacite_min" class="form-label">Capacité min.</label>
                <input type="number" class="form-control" id="capacite_min" name="capacite_min"
                       value="{{filters.capacite_min}}" min="1" placeholder="Min">
            </div>
            <div class="col-md-4">
                <label for="search" class="form-label">Recherche</label>
                <input type="text" class="form-control" id="search" name="search"
                       value="{{filters.search}}" placeholder="Code de salle...">
            </div>
            <div class="col-md-12 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-secondary">
                    <i class="bi bi-search me-2"></i>Filtrer
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{#if salles}}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Pavillon</th>
                        <th>Type</th>
                        <th>Capacité</th>
                        <th>PMR</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each salles}}
                    <tr>
                        <td>
                            <a href="/salles/{{this.id}}" class="fw-bold text-decoration-none">
                                {{this.code}}
                            </a>
                        </td>
                        <td>{{this.pavillon_nom}}</td>
                        <td>
                            <span class="badge bg-info">{{typeSalle this.type}}</span>
                        </td>
                        <td>{{this.capacite}} places</td>
                        <td>
                            {{#if this.accessible_pmr}}
                            <i class="bi bi-check-circle text-success" title="Accessible PMR"></i>
                            {{else}}
                            <i class="bi bi-x-circle text-muted"></i>
                            {{/if}}
                        </td>
                        <td>
                            {{#if this.actif}}
                            <span class="badge bg-success">Active</span>
                            {{else}}
                            <span class="badge bg-secondary">Inactive</span>
                            {{/if}}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="/salles/{{this.id}}" class="btn btn-outline-primary" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/salles/{{this.id}}/edit" class="btn btn-outline-secondary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/salles/{{this.id}}/disponibilites" class="btn btn-outline-info" title="Disponibilités">
                                    <i class="bi bi-calendar-check"></i>
                                </a>
                                <form action="/salles/{{this.id}}/delete" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger" title="Supprimer"
                                            onclick="return confirm('⚠️ SUPPRESSION DE LA SALLE\n\nSalle: {{this.code}}\nType: {{this.type}}\n\nCette action supprimera définitivement la salle.\n\nNote: Si la salle a des horaires planifiés, la suppression sera refusée.\n\nConfirmer la suppression ?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        {{> pagination}}
        {{else}}
        <div class="empty-state">
            <i class="bi bi-door-open"></i>
            <h5 class="mt-3">Aucune salle trouvée</h5>
            <p class="text-muted">Ajoutez une nouvelle salle ou modifiez les filtres</p>
            <a href="/salles/create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Ajouter une salle
            </a>
        </div>
        {{/if}}
    </div>
</div>
