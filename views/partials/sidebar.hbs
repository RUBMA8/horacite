{{#if isAuthenticated}}
<nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse">
    <div class="position-sticky pt-3">
        <ul class="nav flex-column">
            <!-- Dashboard -->
            <li class="nav-item">
                <a class="nav-link {{#eq title 'Tableau de bord'}}active{{/eq}}" href="/dashboard">
                    <i class="bi bi-speedometer2 me-2"></i>
                    Tableau de bord
                </a>
            </li>

            <hr class="my-2">
            <li class="nav-item">
                <small class="nav-link text-muted text-uppercase">Gestion</small>
            </li>

          

           
          
            {{#if (eq user.role 'admin')}}
            <hr class="my-2">
             <!-- Utilisateurs -->
            <li class="nav-item">
                <a class="nav-link {{#eq title 'Gestion des utilisateurs'}}active{{/eq}}" href="/admin/users">
                    <i class="bi bi-person-badge me-2"></i>
                    Utilisateurs
                </a>
            </li>

            <!-- Sessions -->
            <li class="nav-item">
                <a class="nav-link {{#eq title 'Gestion des sessions'}}active{{/eq}}" href="/admin/sessions">
                    <i class="bi bi-calendar-range me-2"></i>
                    Sessions
                </a>
            </li>

            
            {{/if}}
        </ul>

        <!-- Infos session active -->
        <div class="mt-4 p-3 bg-white rounded border">
            <h6 class="text-muted mb-2">
                <i class="bi bi-calendar-event me-1"></i>
                Session active
            </h6>
            {{#if sessionActive}}
            <p class="mb-0 fw-bold">{{sessionActive.nom}}</p>
            <small class="text-muted">
                {{formatDate sessionActive.date_debut}} - {{formatDate sessionActive.date_fin}}
            </small>
            {{else}}
            <p class="mb-0 text-warning">Aucune session active</p>
            {{/if}}
        </div>
    </div>
</nav>
{{/if}}
