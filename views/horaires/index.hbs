<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-calendar-week me-2"></i>Gestion des Horaires</h2>
        {{#if sessionActive}}
        <p class="text-muted mb-0">
            <i class="bi bi-bookmark-fill me-1"></i>
            <strong>Session:</strong> {{sessionActive.nom}}
            <span class="ms-3"><i class="bi bi-calendar-range me-1"></i>{{formatDate sessionActive.date_debut}} - {{formatDate sessionActive.date_fin}}</span>
        </p>
        {{/if}}
    </div>
    <a href="/horaires/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Nouvel horaire
    </a>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-funnel me-2"></i>Filtres
    </div>
    <div class="card-body">
        <form action="/horaires" method="GET" class="row g-3">
            <input type="hidden" name="view" value="{{view}}">
            <div class="col-md-3">
                <label for="session_id" class="form-label">Session</label>
                <select class="form-select" id="session_id" name="session_id" onchange="this.form.submit()">
                    {{#each sessions}}
                    <option value="{{this.id}}" {{selected this.id ../filters.session_id}}>
                        {{this.nom}}
                    </option>
                    {{/each}}
                </select>
            </div>
            <div class="col-md-3">
                <label for="jour" class="form-label">Jour</label>
                <select class="form-select" id="jour" name="jour" onchange="this.form.submit()">
                    <option value="">Tous les jours</option>
                    <option value="1" {{selected "1" filters.jour}}>Lundi</option>
                    <option value="2" {{selected "2" filters.jour}}>Mardi</option>
                    <option value="3" {{selected "3" filters.jour}}>Mercredi</option>
                    <option value="4" {{selected "4" filters.jour}}>Jeudi</option>
                    <option value="5" {{selected "5" filters.jour}}>Vendredi</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="professeur_id" class="form-label">Professeur</label>
                <select class="form-select" id="professeur_id" name="professeur_id" onchange="this.form.submit()">
                    <option value="">Tous les professeurs</option>
                    {{#each professeurs}}
                    <option value="{{this.id}}" {{selected this.id ../filters.professeur_id}}>
                        {{this.prenom}} {{this.nom}}
                    </option>
                    {{/each}}
                </select>
            </div>
            <div class="col-md-3">
                <label for="salle_id" class="form-label">Salle</label>
                <select class="form-select" id="salle_id" name="salle_id" onchange="this.form.submit()">
                    <option value="">Toutes les salles</option>
                    {{#each salles}}
                    <option value="{{this.id}}" {{selected this.id ../filters.salle_id}}>
                        {{this.code}}
                    </option>
                    {{/each}}
                </select>
            </div>
        </form>
    </div>
</div>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link {{#eq view 'list'}}active{{/eq}}" href="/horaires?view=list&session_id={{filters.session_id}}">
            <i class="bi bi-list-ul me-2"></i>Liste
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{#eq view 'calendar'}}active{{/eq}}" href="/horaires?view=calendar&session_id={{filters.session_id}}">
            <i class="bi bi-calendar3 me-2"></i>Calendrier
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link {{#eq view 'grid'}}active{{/eq}}" href="/horaires?view=grid&session_id={{filters.session_id}}">
            <i class="bi bi-grid-3x3 me-2"></i>Grille
        </a>
    </li>
</ul>

{{#eq view 'list'}}
<div class="card">
    <div class="card-body">
        {{#if horaires}}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Jour</th>
                        <th>Heure</th>
                        <th>Cours</th>
                        <th>Professeur</th>
                        <th>Salle</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each horaires}}
                    <tr>
                        <td>{{jourSemaine this.jour_semaine}}</td>
                        <td>{{formatTime this.heure_debut}} - {{formatTime this.heure_fin}}</td>
                        <td>
                            <span class="badge bg-primary me-1">{{this.cours_code}}</span>
                            {{this.cours_nom}}
                        </td>
                        <td>{{this.professeur_prenom}} {{this.professeur_nom}}</td>
                        <td>{{this.salle_code}}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a href="/horaires/{{this.id}}/edit" class="btn btn-outline-secondary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-outline-danger" title="Supprimer"
                                        data-confirm="Êtes-vous sûr de vouloir supprimer cet horaire ?"
                                        onclick="deleteHoraire({{this.id}})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        {{> pagination}}
        {{else}}
        <div class="empty-state">
            <i class="bi bi-calendar-x"></i>
            <h5 class="mt-3">Aucun horaire trouvé</h5>
            <p class="text-muted">Créez un nouvel horaire ou modifiez les filtres</p>
            <a href="/horaires/create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Créer un horaire
            </a>
        </div>
        {{/if}}
    </div>
</div>
{{/eq}}

{{#eq view 'grid'}}
<div class="card">
    <div class="card-body">
        <div class="schedule-grid">
            {{#each jours}}
            <div class="schedule-day">
                <div class="schedule-day-header">{{this.nom}}</div>
                {{#each this.horaires}}
                <div class="schedule-item">
                    <div class="time">{{formatTime this.heure_debut}} - {{formatTime this.heure_fin}}</div>
                    <div class="course">{{this.cours_code}}</div>
                    <div class="location">
                        <i class="bi bi-geo-alt me-1"></i>{{this.salle_code}}
                    </div>
                    <small class="text-muted">{{this.professeur_nom}}</small>
                </div>
                {{else}}
                <p class="text-muted small">Aucun cours</p>
                {{/each}}
            </div>
            {{/each}}
        </div>
    </div>
</div>
{{/eq}}

{{#eq view 'calendar'}}
<div class="card">
    <div class="card-body">
        <div id="calendar"></div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('calendar');
    const sessionDateDebut = '{{sessionActive.date_debut}}';
    const sessionDateFin = '{{sessionActive.date_fin}}';

    const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'timeGridWeek',
        initialDate: sessionDateDebut || new Date(),
        validRange: sessionDateDebut ? {
            start: sessionDateDebut,
            end: sessionDateFin
        } : undefined,
        locale: 'fr',
        weekends: false,
        slotMinTime: '08:00:00',
        slotMaxTime: '22:00:00',
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'timeGridWeek,timeGridDay'
        },
        events: {{{calendarData}}},
        eventClick: function(info) {
            window.location.href = '/horaires/' + info.event.id + '/edit';
        }
    });
    calendar.render();
});
</script>
{{/eq}}

<script>
function deleteHoraire(id) {
    if (confirm('Êtes-vous sûr de vouloir supprimer cet horaire ?')) {
        fetch('/horaires/' + id + '/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        }).then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                alert('Erreur lors de la suppression');
            }
        });
    }
}
</script>
