<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="HoraCité - Système de Gestion des Horaires Académiques">
    <title>{{title}} - HoraCité</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="/css/style.css" rel="stylesheet">

    {{#if calendarData}}
    <!-- FullCalendar - CSS intégré dans le JS pour v6.x -->
    {{/if}}
</head>
<body>
    <!-- Navbar -->
    {{> navbar}}

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            {{> sidebar}}

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mt-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/dashboard">Accueil</a></li>
                        {{#if breadcrumb}}
                        {{#each breadcrumb}}
                        <li class="breadcrumb-item {{#if active}}active{{/if}}" {{#if active}}aria-current="page"{{/if}}>
                            {{#if url}}<a href="{{url}}">{{label}}</a>{{else}}{{label}}{{/if}}
                        </li>
                        {{/each}}
                        {{else}}
                        <li class="breadcrumb-item active" aria-current="page">{{title}}</li>
                        {{/if}}
                    </ol>
                </nav>

                <!-- Messages flash -->
                {{> flash-messages}}

                <!-- Page title -->
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">{{title}}</h1>
                    {{#if headerActions}}
                    <div class="btn-toolbar mb-2 mb-md-0">
                        {{{headerActions}}}
                    </div>
                    {{/if}}
                </div>

                <!-- Page content -->
                {{{body}}}
            </main>
        </div>
    </div>

    <!-- Footer -->
    {{> footer}}

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    {{#if calendarData}}
    <!-- FullCalendar JS -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    {{/if}}

    <!-- Custom JS -->
    <script src="/js/main.js"></script>

    {{#if pageScript}}
    <script>{{{pageScript}}}</script>
    {{/if}}
</body>
</html>
