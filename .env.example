# ============================================
# HoraCité - Configuration Environnement
# ============================================
# Copiez ce fichier vers .env et modifiez les valeurs

# Environnement (development, production, test)
NODE_ENV=development

# Port du serveur
PORT=3000

# Secret pour les sessions (CHANGER EN PRODUCTION!)
SESSION_SECRET=horacite_dev_secret_change_this_in_production_2026

# Durée de session en millisecondes (30 minutes = 1800000)
SESSION_TIMEOUT=1800000

# Base de données SQLite
DB_PATH=./database/horaires.db

# Nombre de rounds pour bcrypt (10-12 recommandé)
BCRYPT_ROUNDS=12

# CORS Origin
CORS_ORIGIN=http://localhost:3000

# Tentatives de connexion max avant blocage
MAX_LOGIN_ATTEMPTS=5
